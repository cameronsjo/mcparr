# Servarr MCP Server Configuration
# Copy to .env and fill in your values

# Server
SERVARR_HOST=0.0.0.0
SERVARR_PORT=8080
SERVARR_PATH=/mcp
SERVARR_LOG_LEVEL=info

# Sonarr (TV Shows)
SERVARR_SONARR_URL=http://sonarr:8989
SERVARR_SONARR_API_KEY=

# Radarr (Movies)
SERVARR_RADARR_URL=http://radarr:7878
SERVARR_RADARR_API_KEY=

# Prowlarr (Indexers)
SERVARR_PROWLARR_URL=http://prowlarr:9696
SERVARR_PROWLARR_API_KEY=

# SABnzbd (Downloads)
SERVARR_SABNZBD_URL=http://sabnzbd:8080
SERVARR_SABNZBD_API_KEY=

# Bazarr (Subtitles)
SERVARR_BAZARR_URL=http://bazarr:6767
SERVARR_BAZARR_API_KEY=
