# mcparr MCP Server Configuration
# Copy to .env and fill in your values

# Server
MCPARR_HOST=0.0.0.0
MCPARR_PORT=8080
MCPARR_PATH=/mcp
MCPARR_LOG_LEVEL=info

# Sonarr (TV Shows)
MCPARR_SONARR_URL=http://sonarr:8989
MCPARR_SONARR_API_KEY=

# Radarr (Movies)
MCPARR_RADARR_URL=http://radarr:7878
MCPARR_RADARR_API_KEY=

# Prowlarr (Indexers)
MCPARR_PROWLARR_URL=http://prowlarr:9696
MCPARR_PROWLARR_API_KEY=

# SABnzbd (Downloads)
MCPARR_SABNZBD_URL=http://sabnzbd:8080
MCPARR_SABNZBD_API_KEY=

# Bazarr (Subtitles)
MCPARR_BAZARR_URL=http://bazarr:6767
MCPARR_BAZARR_API_KEY=
